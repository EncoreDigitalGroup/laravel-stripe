{
    "name": "@encoredigitalgroup/common-stripe",
    "scripts": {
        "build": "bun run json:sort && bun run fix && bun scripts/build.js",
        "fix": "prettier --write 'src/ts/**/*'",
        "json:sort": "jsonsort --indentationCount=4 tsconfig.json && jsonsort --indentationCount=4 package.json",
        "postinstall": "bun run json:sort"
    },
    "devDependencies": {
        "@stripe/stripe-js": "^5.6.0",
        "@trivago/prettier-plugin-sort-imports": "^5.2.2",
        "@types/bun": "latest",
        "@types/node": "^22.13.5",
        "axios": "^1.15.2",
        "esbuild": "^0.28.1",
        "json-sort-cli": "^4.0.4",
        "typescript": "^5.6.3"
    },
    "engines": {
        "bun": ">=1.2.0"
    }
}
